<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
"http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="com.parchlinux.mirrorman.Helper">
    <method name="SaveMirrorlist">
      <arg name="content" type="s" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>
    <method name="SavePacmanConf">
      <arg name="content" type="s" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>
    <method name="RunPacman">
      <arg name="args" type="as" direction="in"/>
      <arg name="success" type="b" direction="out"/>
      <arg name="stdout" type="s" direction="out"/>
      <arg name="stderr" type="s" direction="out"/>
    </method>
    <method name="RunCommand">
      <arg name="command" type="s" direction="in"/>
      <arg name="args" type="as" direction="in"/>
      <arg name="success" type="b" direction="out"/>
      <arg name="stdout" type="s" direction="out"/>
      <arg name="stderr" type="s" direction="out"/>
    </method>
  </interface>
</node>
